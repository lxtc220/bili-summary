# AI 模型配置 (支持所有兼容 OpenAI 接口的服务商)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
MODEL_ID=deepseek-ai/DeepSeek-V4-Flash

# 常用服务商示例：
# 魔搭社区 (ModelScope) [推荐]: https://api-inference.modelscope.cn/v1 | model: deepseek-ai/DeepSeek-V4-Flash
# DeepSeek 官方: https://api.deepseek.com | model: deepseek-chat
# 火山引擎 (豆包): https://ark.cn-beijing.volces.com/api/v3 | model: 填写你的推理终端ID
# 硅基流动: https://api.siliconflow.cn/v1 | model: deepseek-ai/DeepSeek-V3

# FFmpeg 路径（可选，如果不设置则默认使用当前目录下的 ffmpeg 文件夹）
# FFMPEG_PATH=C:\path\to\ffmpeg\bin

# B 站下载增强配置（可选，但遇到 412 时建议配置）
# BILIBILI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# BILIBILI_COOKIE_FILE=C:\path\to\bilibili_cookies.txt
# BILIBILI_COOKIES_FROM_BROWSER=chrome
# BILIBILI_REFERER=https://www.bilibili.com/
# BILIBILI_ORIGIN=https://www.bilibili.com
